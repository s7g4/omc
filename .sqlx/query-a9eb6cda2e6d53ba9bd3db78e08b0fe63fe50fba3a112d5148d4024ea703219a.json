  "query": "\n        SELECT rt.id, rt.user_id, rt.expires_at, rt.revoked_at, u.username, u.role\n        FROM refresh_tokens rt\n        JOIN users u ON u.id = rt.user_id\n        WHERE rt.token_hash = $1\n        ",
