# Copy to .env (backend reads it via dotenvy) and adjust as needed.
# All of these have working defaults for local `docker compose up -d` + `cargo run` —
# you only need this file if you're overriding something.

# --- Required ---
DATABASE_URL=postgresql://postgres:password123@127.0.0.1:5433/omc

# --- Optional (defaults shown) ---
REDIS_URL=redis://127.0.0.1:6380
NATS_URL=nats://127.0.0.1:4222
JWT_SECRET=mission_control_default_secret_key_12345

# Backend HTTP (Axum) and gRPC (tonic) bind addresses. Docker/production sets these to
# 0.0.0.0 (see backend/Dockerfile); local dev defaults to loopback-only.
HTTP_HOST=127.0.0.1
HTTP_PORT=8081
GRPC_HOST=[::1]
GRPC_PORT=50051

# Which backend/config/{APP_ENV}.toml overlay to load on top of base.toml (see
# backend/src/settings.rs). "development" or "production".
APP_ENV=development

# Layered-config overrides use double-underscore nesting, e.g. to raise the rate limit burst:
# APP__RATE_LIMIT__BURST_SIZE=50
# To point tracing at a local Jaeger instance (docker-compose.yml's `jaeger` service):
# APP__OTEL__OTLP_ENDPOINT=http://127.0.0.1:4317
# APP__OTEL__ENABLED=false   # disable tracing export entirely

# --- Simulator ---
# GRPC_URL=http://[::1]:50051
